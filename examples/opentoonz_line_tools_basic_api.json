{
  "1": {
    "class_type": "LoadImage",
    "inputs": {
      "image": "panel_001.png"
    }
  },
  "2": {
    "class_type": "OTBlueLineCleanup",
    "inputs": {
      "image": ["1", 0],
      "hue_low": 90,
      "hue_high": 145,
      "saturation_min": 28,
      "value_min": 20,
      "include_dark_lines": false,
      "despeckle_px": 8,
      "close_px": 1
    }
  },
  "3": {
    "class_type": "OTLineAutoClose",
    "inputs": {
      "image": ["2", 0],
      "threshold": 180,
      "closing_distance": 18,
      "spot_angle": 75.0,
      "line_width": 1,
      "max_endpoints": 600
    }
  },
  "4": {
    "class_type": "OTRegionPaletteMap",
    "inputs": {
      "image": ["3", 0],
      "threshold": 180,
      "min_area": 32,
      "max_regions": 128,
      "ignore_border_regions": true
    }
  },
  "5": {
    "class_type": "SaveImage",
    "inputs": {
      "images": ["2", 0],
      "filename_prefix": "opentoonz_line_tools/01_clean_line"
    }
  },
  "6": {
    "class_type": "SaveImage",
    "inputs": {
      "images": ["2", 1],
      "filename_prefix": "opentoonz_line_tools/02_cleanup_overlay"
    }
  },
  "7": {
    "class_type": "SaveImage",
    "inputs": {
      "images": ["3", 1],
      "filename_prefix": "opentoonz_line_tools/03_closure_overlay"
    }
  },
  "8": {
    "class_type": "SaveImage",
    "inputs": {
      "images": ["4", 0],
      "filename_prefix": "opentoonz_line_tools/04_region_preview"
    }
  }
}
